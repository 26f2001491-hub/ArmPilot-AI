# Application
APP_NAME=ArmPilot-AI
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security / JWT
# Generate a real secret with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (async SQLAlchemy, Postgres via asyncpg)
# Local dev (Postgres reachable on localhost): postgresql+asyncpg://armpilot:armpilot_dev_pw@localhost:5432/armpilot
# Inside docker-compose (backend container talking to the `db` service): postgresql+asyncpg://armpilot:armpilot_dev_pw@db:5432/armpilot
DATABASE_URL=postgresql+asyncpg://armpilot:armpilot_dev_pw@localhost:5432/armpilot

# CORS (JSON array of allowed origins)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Postgres container settings (consumed by docker/docker-compose.yml, must match DATABASE_URL above)
POSTGRES_USER=armpilot
POSTGRES_PASSWORD=armpilot_dev_pw
POSTGRES_DB=armpilot
