# Copy to .env and adjust for your environment.
APP_NAME=ArmPilot-AI
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Generate a strong value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Async SQLAlchemy URL. Postgres (asyncpg) for production, or sqlite+aiosqlite for local dev:
#   sqlite+aiosqlite:///./armpilot.db
DATABASE_URL=postgresql+asyncpg://armpilot:armpilot_dev_pw@localhost:5432/armpilot

BACKEND_CORS_ORIGINS=["http://localhost:3000"]

LOG_LEVEL=INFO
LOG_DIR=logs
